{
    "name": "flipkart-clone",
    "version": "1.0.0",
    "private": true,
    "workspaces": [
        "apps/*",
        "packages/*"
    ],
    "scripts": {
        "dev": "concurrently \"npm run dev -w @flipkart-clone/api\" \"npm run dev -w @flipkart-clone/web\"",
        "build": "npm run build -w @flipkart-clone/shared && npm run build -w @flipkart-clone/api && npm run build -w @flipkart-clone/web",
        "lint": "npm run lint --workspaces --if-present",
        "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\""
    },
    "devDependencies": {
        "concurrently": "^9.2.1",
        "prettier": "^3.2.5"
    }
}